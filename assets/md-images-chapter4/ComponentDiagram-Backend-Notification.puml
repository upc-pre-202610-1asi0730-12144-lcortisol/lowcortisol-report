@startuml
title LowCortisol Platform - Notification Backend Component Diagram

!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Component.puml

LAYOUT_WITH_LEGEND()

Container(spa, "Single Page Application", "Vue / Vite", "Consumes notification backend endpoints.")
System_Ext(emailProvider, "Email Provider", "External service used to send alert and incident notifications.")
ContainerDb(database, "Database", "SQL Server / PostgreSQL", "Stores alerts, thresholds, incidents, channels, and deliveries.")

Container_Boundary(notification, "Notification") {

  Component(rest, "interfaces/rest", "ASP.NET Core Controllers", "Exposes alert, threshold, incident, channel, and delivery endpoints.")

  Component(application, "application", "Application Services / Commands / DTOs", "Coordinates alert creation, resolution, closing, threshold creation, incident creation, and delivery registration.")

  Component(domain, "domain", "Domain Model / Business Rules", "Contains Alert, Threshold, Incident, NotificationChannel, AlertDelivery, and notification rules.")

  Component(infrastructure, "infrastructure", "Repositories / Persistence Services", "Implements repositories and database access for notification data.")

  Component(deliveryConnector, "Delivery Connector", "Email Service Adapter", "Sends alert notifications through an external provider.")
}

Rel(spa, rest, "Consumes notification endpoints", "HTTPS/JSON")

Rel(rest, application, "Delegates commands and queries")
Rel(application, domain, "Applies notification rules")
Rel(application, infrastructure, "Uses repositories and persistence services")
Rel(application, deliveryConnector, "Sends notification messages")

Rel(infrastructure, database, "Reads and writes notification data", "EF Core")
Rel(deliveryConnector, emailProvider, "Sends alert emails", "SMTP/HTTPS")

@enduml