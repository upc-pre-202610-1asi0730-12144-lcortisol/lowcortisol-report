@startuml
title LowCortisol Platform - Backend General Component Diagram

!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Component.puml

LAYOUT_WITH_LEGEND()

Container(spa, "Single Page Application", "Vue / Vite", "Consumes backend capabilities.")
ContainerDb(database, "Database", "SQL Server / PostgreSQL", "Stores persistent platform data.")

Container_Boundary(api, "Backend API") {

  Component(iam, "IAM", "Bounded Context", "Identity, access, profiles, permissions, and sessions.")
  Component(plan, "Plan", "Bounded Context", "Plans, subscriptions, payments, and service requests.")
  Component(workplace, "Workplace", "Bounded Context", "Workplaces, sites, members, and assignments.")
  Component(deviceControl, "Device Control", "Bounded Context", "Devices, sensors, valves, and commands.")
  Component(monitoring, "Monitoring", "Bounded Context", "Sessions, readings, anomalies, and reports.")
  Component(notification, "Notification", "Bounded Context", "Alerts, thresholds, incidents, channels, and deliveries.")
  Component(support, "Support", "Bounded Context", "Tickets, messages, conversations, agents, and knowledge articles.")
}

Rel(spa, iam, "Consumes IAM endpoints", "HTTPS/JSON")
Rel(spa, plan, "Consumes plan endpoints", "HTTPS/JSON")
Rel(spa, workplace, "Consumes workplace endpoints", "HTTPS/JSON")
Rel(spa, deviceControl, "Consumes device control endpoints", "HTTPS/JSON")
Rel(spa, monitoring, "Consumes monitoring endpoints", "HTTPS/JSON")
Rel(spa, notification, "Consumes notification endpoints", "HTTPS/JSON")
Rel(spa, support, "Consumes support endpoints", "HTTPS/JSON")

Rel(iam, database, "Persists IAM data")
Rel(plan, database, "Persists plan data")
Rel(workplace, database, "Persists workplace data")
Rel(deviceControl, database, "Persists device control data")
Rel(monitoring, database, "Persists monitoring data")
Rel(notification, database, "Persists notification data")
Rel(support, database, "Persists support data")

@enduml