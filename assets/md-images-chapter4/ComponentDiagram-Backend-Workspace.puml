@startuml
title LowCortisol Platform - Workplace Backend Component Diagram

!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Component.puml

LAYOUT_WITH_LEGEND()

Container(spa, "Single Page Application", "Vue / Vite", "Consumes workplace backend endpoints.")
ContainerDb(database, "Database", "SQL Server / PostgreSQL", "Stores workplaces, sites, members, and device assignments.")

Container_Boundary(workplace, "Workplace") {

  Component(rest, "interfaces/rest", "ASP.NET Core Controllers", "Exposes workplace, site, member, and assignment endpoints.")

  Component(application, "application", "Application Services / Commands / DTOs", "Coordinates workplace retrieval, site creation, site filtering, member assignment, device assignment, and summary generation.")

  Component(domain, "domain", "Domain Model / Business Rules", "Contains Workplace, Site, SiteMember, SiteDeviceAssignment, and workplace rules.")

  Component(infrastructure, "infrastructure", "Repositories / Persistence Services", "Implements repositories and database access for workplaces, sites, members, and assignments.")
}

Rel(spa, rest, "Consumes workplace endpoints", "HTTPS/JSON")

Rel(rest, application, "Delegates commands and queries")
Rel(application, domain, "Applies workplace business rules")
Rel(application, infrastructure, "Uses repositories and persistence services")

Rel(infrastructure, database, "Reads and writes workplace data", "EF Core")

@enduml