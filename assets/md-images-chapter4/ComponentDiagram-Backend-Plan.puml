@startuml
title LowCortisol Platform - Plan Backend Component Diagram

!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Component.puml

LAYOUT_WITH_LEGEND()

Container(spa, "Single Page Application", "Vue / Vite", "Consumes plan backend endpoints.")
System_Ext(paymentProvider, "Payment Provider", "External service projected for subscription payment processing.")
ContainerDb(database, "Database", "SQL Server / PostgreSQL", "Stores plans, features, subscriptions, payments, and service requests.")

Container_Boundary(plan, "Plan") {

  Component(rest, "interfaces/rest", "ASP.NET Core Controllers", "Exposes plan, subscription, payment, and service request endpoints.")

  Component(application, "application", "Application Services / Commands / DTOs", "Coordinates listing plans, subscribing, changing plans, cancelling subscriptions, recording payments, and service requests.")

  Component(domain, "domain", "Domain Model / Business Rules", "Contains Plan, PlanFeature, Subscription, Payment, ServiceRequest, and subscription rules.")

  Component(infrastructure, "infrastructure", "Repositories / Persistence Services", "Implements repositories and database access for plans, subscriptions, payments, and service requests.")

  Component(paymentConnector, "Payment Connector", "Payment Service Adapter", "Processes subscription payments through an external provider.")
}

Rel(spa, rest, "Consumes plan endpoints", "HTTPS/JSON")

Rel(rest, application, "Delegates commands and queries")
Rel(application, domain, "Applies plan and subscription rules")
Rel(application, infrastructure, "Uses repositories and persistence services")
Rel(application, paymentConnector, "Processes payment operations")

Rel(infrastructure, database, "Reads and writes plan data", "EF Core")
Rel(paymentConnector, paymentProvider, "Processes real payments", "HTTPS")

@enduml