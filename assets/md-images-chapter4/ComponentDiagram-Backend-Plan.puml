@startuml
title LowCortisol Platform - Plan Context - Backend Component Diagram

!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Component.puml

LAYOUT_WITH_LEGEND()

Container(spa, "Single Page Application", "Vue / Vite", "Consumes plan backend endpoints for listing plans, buying subscriptions, changing plans, cancelling subscriptions, and reviewing payments.")

System_Ext(paymentProvider, "Payment Provider", "External payment service projected for processing real subscription payments.")

ContainerDb(database, "LowCortisol Database", "SQL Server / PostgreSQL", "Stores plans, plan features, subscriptions, payments, service requests, users, and workplaces.")

Container_Boundary(planContext, "Plan Bounded Context") {

  Component(interfaceLayer, "Interface Layer", "ASP.NET Core Controllers", "Exposes plan, subscription, payment, and service request endpoints through PlanController, SubscriptionController, PaymentController, and ServiceRequestController.")

  Component(applicationLayer, "Application Layer", "Application Services / Commands / DTOs", "Coordinates plan use cases such as listing plans, subscribing, changing plans, cancelling subscriptions, recording payments, and generating summaries.")

  Component(domainLayer, "Domain Layer", "Domain Model / Business Rules", "Contains Plan, PlanFeature, Subscription, Payment, ServiceRequest, and subscription business rules.")

  Component(infrastructureLayer, "Infrastructure Layer", "Repositories / Persistence Services", "Implements repositories and database access for plans, subscriptions, payments, and service requests.")

  Component(paymentConnector, "Payment Connector", "Payment Service Adapter", "Processes subscription payments through an external payment provider.")

  Component(subscriptionPolicy, "Subscription Policy", "Domain Service", "Validates rules for subscribing, changing plans, cancelling subscriptions, and requiring payments.")
}

Rel(spa, interfaceLayer, "Consumes plan endpoints", "HTTPS/JSON")

Rel(interfaceLayer, applicationLayer, "Delegates commands and queries")
Rel(applicationLayer, domainLayer, "Applies plan and subscription business rules")
Rel(applicationLayer, infrastructureLayer, "Uses repositories and persistence services")

Rel(applicationLayer, subscriptionPolicy, "Validates subscription rules")
Rel(applicationLayer, paymentConnector, "Processes payment operations")
Rel(paymentConnector, paymentProvider, "Processes real payments", "HTTPS")

Rel(infrastructureLayer, database, "Reads and writes plan context data", "EF Core")

@enduml