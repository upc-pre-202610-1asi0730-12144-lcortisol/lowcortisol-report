@startuml
title LowCortisol Platform - Device Control Backend Component Diagram

!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Component.puml

LAYOUT_WITH_LEGEND()

Container(spa, "Single Page Application", "Vue / Vite", "Consumes device control backend endpoints.")
System_Ext(iotNetwork, "IoT Network", "External network of hubs, sensors, and valves.")
ContainerDb(database, "Database", "SQL Server / PostgreSQL", "Stores devices, sensors, valves, and commands.")

Container_Boundary(deviceControl, "Device Control") {

  Component(rest, "interfaces/rest", "ASP.NET Core Controllers", "Exposes device, sensor, valve, and command endpoints.")

  Component(application, "application", "Application Services / Commands / DTOs", "Coordinates device creation, sensor linking, valve control, command execution, and summaries.")

  Component(domain, "domain", "Domain Model / Business Rules", "Contains Device, Sensor, Valve, DeviceCommand, and device operation rules.")

  Component(infrastructure, "infrastructure", "Repositories / Persistence Services", "Implements repositories, database access, and device communication support.")

  Component(iotConnector, "IoT Connector", "IoT Service Adapter", "Sends remote commands and retrieves device-related data.")
}

Rel(spa, rest, "Consumes device control endpoints", "HTTPS/JSON")

Rel(rest, application, "Delegates commands and queries")
Rel(application, domain, "Applies device control rules")
Rel(application, infrastructure, "Uses repositories and infrastructure services")
Rel(application, iotConnector, "Executes device operations")

Rel(infrastructure, database, "Reads and writes device control data", "EF Core")
Rel(iotConnector, iotNetwork, "Communicates with devices", "HTTP/MQTT")

@enduml