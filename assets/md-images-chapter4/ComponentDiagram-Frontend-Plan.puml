@startuml
title LowCortisol Platform - Plan Frontend Component Diagram

!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Component.puml

LAYOUT_WITH_LEGEND()

Container(spa, "Single Page Application", "Vue / Vite", "Provides subscription management.")
Container(api, "Backend API", "ASP.NET Core Web API", "Provides plan, subscription, payment, and service request endpoints.")

Container_Boundary(plan, "Plan") {

  Component(presentation, "Presentation", "Vue Screens / Components", "Contains plan screen, plan cards, payment form, subscription status, payment history, and service request section.")

  Component(application, "Application", "Pinia Store / Facade", "Coordinates loading plans, subscribing, changing plan, cancelling subscription, loading payments, and loading service requests.")

  Component(domain, "Domain", "Domain Model", "Contains Plan, PlanFeature, Subscription, Payment, and ServiceRequest frontend concepts.")

  Component(infrastructure, "Infrastructure", "API Service", "Consumes plan backend endpoints and adapts responses to frontend models.")
}

Rel(spa, presentation, "Uses plan screens", "Vue Router")

Rel(presentation, application, "Dispatches plan actions")
Rel(application, domain, "Uses plan models")
Rel(application, infrastructure, "Delegates API operations")

Rel(infrastructure, api, "Consumes plan endpoints", "HTTPS/JSON")

@enduml