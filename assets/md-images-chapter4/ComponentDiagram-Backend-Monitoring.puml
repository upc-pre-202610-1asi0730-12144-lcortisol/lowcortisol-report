@startuml
title LowCortisol Platform - Monitoring Context - Backend Component Diagram

!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Component.puml

LAYOUT_WITH_LEGEND()

Container(spa, "Single Page Application", "Vue / Vite", "Consumes monitoring backend endpoints for dashboard metrics, readings, anomalies, sessions, and reports.")

System_Ext(iotNetwork, "IoT Sensor and Device Network", "External source projected for real water and gas readings.")

ContainerDb(database, "LowCortisol Database", "SQL Server / PostgreSQL", "Stores monitoring sessions, readings, anomalies, reports, sensors, and sites.")

Container_Boundary(monitoringContext, "Monitoring Bounded Context") {

  Component(interfaceLayer, "Interface Layer", "ASP.NET Core Controllers", "Exposes monitoring, reading, anomaly, and report endpoints through MonitoringController, ReadingController, AnomalyController, and ReportController.")

  Component(applicationLayer, "Application Layer", "Application Services / Commands / DTOs", "Coordinates monitoring use cases such as loading dashboard summaries, registering readings, detecting anomalies, retrieving sessions, and generating reports.")

  Component(domainLayer, "Domain Layer", "Domain Model / Business Rules", "Contains MonitoringSession, Reading, Anomaly, Report, and monitoring business rules.")

  Component(infrastructureLayer, "Infrastructure Layer", "Repositories / Persistence Services", "Implements repositories and database access for monitoring sessions, readings, anomalies, and reports.")

  Component(anomalyDetectionService, "Anomaly Detection Service", "Domain Service", "Detects anomalies by evaluating readings against thresholds and monitoring rules.")

  Component(readingIngestionConnector, "Reading Ingestion Connector", "IoT Service Adapter", "Receives or retrieves readings from the IoT sensor and device network.")
}

Rel(spa, interfaceLayer, "Consumes monitoring endpoints", "HTTPS/JSON")

Rel(interfaceLayer, applicationLayer, "Delegates commands and queries")
Rel(applicationLayer, domainLayer, "Applies monitoring business rules")
Rel(applicationLayer, infrastructureLayer, "Uses repositories and persistence services")

Rel(applicationLayer, anomalyDetectionService, "Detects anomalies from readings")
Rel(applicationLayer, readingIngestionConnector, "Gets real sensor readings")
Rel(readingIngestionConnector, iotNetwork, "Retrieves readings", "HTTP/MQTT/IoT API")

Rel(infrastructureLayer, database, "Reads and writes monitoring context data", "EF Core")

@enduml