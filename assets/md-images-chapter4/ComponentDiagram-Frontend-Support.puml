@startuml
title LowCortisol Platform - Support Frontend Component Diagram

!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Component.puml

LAYOUT_WITH_LEGEND()

Container(spa, "Single Page Application", "Vue / Vite", "Provides support ticket management.")
Container(api, "Backend API", "ASP.NET Core Web API", "Provides support endpoints.")

Container_Boundary(support, "Support") {

  Component(presentation, "Presentation", "Vue Screens / Components", "Contains support screen, ticket list, ticket detail, conversation area, message form, and knowledge article section.")

  Component(application, "Application", "Pinia Store / Facade", "Coordinates ticket loading, ticket creation, ticket selection, message sending, ticket resolution, ticket closing, and article loading.")

  Component(domain, "Domain", "Domain Model", "Contains SupportTicket, SupportMessage, SupportAgent, SupportConversation, and KnowledgeArticle frontend concepts.")

  Component(infrastructure, "Infrastructure", "API Service", "Consumes support backend endpoints and adapts responses to frontend models.")
}

Rel(spa, presentation, "Uses support screens", "Vue Router")

Rel(presentation, application, "Dispatches support actions")
Rel(application, domain, "Uses support models")
Rel(application, infrastructure, "Delegates API operations")

Rel(infrastructure, api, "Consumes support endpoints", "HTTPS/JSON")

@enduml