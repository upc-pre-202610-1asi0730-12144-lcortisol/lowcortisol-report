@startuml
title LowCortisol Platform - Workplace Context - Frontend Component Diagram

!define C4Puml https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master
!includeurl C4Puml/C4_Component.puml

LAYOUT_WITH_LEGEND()

Container(spa, "Single Page Application", "Vue / Vite", "Provides workplace and site management through the web browser, including site registration, filtering, member assignment, and device assignment.")

System_Ext(api, "LowCortisol API", "Backend API that provides workplace, site, site member, and site device assignment endpoints.")
System_Ext(i18nFiles, "i18n JSON Files", "Translation files: es.json, en.json, pt.json.")

Container_Boundary(workplaceContext, "Workplace Bounded Context") {

  Component(presentationLayer, "Presentation Layer", "Vue Page / Components", "Contains the site page, site filter, site cards, member assignment forms, and device assignment actions. Handles user interaction for workplace management.")

  Component(applicationLayer, "Application Layer", "Pinia Store / Facade", "Coordinates workplace use cases such as loading workplace data, filtering sites, creating sites, assigning members, assigning devices, and loading summary data.")

  Component(domainLayer, "Domain Layer", "Domain Model", "Contains Workplace, Site, SiteMember, and SiteDeviceAssignment business concepts.")

  Component(infrastructureLayer, "Infrastructure Layer", "API Services", "Consumes workplace, site, site member, and site device assignment backend endpoints and adapts API responses to frontend models.")

  Component(sharedLayer, "Shared Layer", "Shared Services / Components", "Provides reusable layout, translated texts, route guards, subscription access validation, reusable UI components, and HTTP communication.")
}

Rel(spa, presentationLayer, "Uses workplace views", "Vue Router")

Rel(presentationLayer, applicationLayer, "Dispatches workplace actions")
Rel(applicationLayer, domainLayer, "Uses domain models")
Rel(applicationLayer, infrastructureLayer, "Delegates API operations")

Rel(presentationLayer, sharedLayer, "Uses shared layout, cards, language switcher, and route guards")
Rel(applicationLayer, sharedLayer, "Uses subscription access and session services")
Rel(infrastructureLayer, sharedLayer, "Uses ApiClientService")

Rel(sharedLayer, i18nFiles, "Loads translations", "HTTP GET")
Rel(infrastructureLayer, api, "Consumes workplace context endpoints", "HTTPS/JSON")

@enduml